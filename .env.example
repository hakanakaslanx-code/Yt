# ── AI API Keys ───────────────────────────────────────
KIE_API_KEY=your_kie_ai_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_key_here

# ── YouTube API ───────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Flask ─────────────────────────────────────────────
FLASK_SECRET=your_random_secret_key_here

# ── Paths (isteğe bağlı, varsayılan: proje klasörü) ───
# APP_BASE_DIR=/root/Yt
# VIDEOS_DIR=/root/Yt/outputs
# ENV_FILE=/root/Yt/.env
# CLIENT_SECRETS_FILE=/root/Yt/client_secrets.json
# TOKEN_FILE=/root/Yt/token.pickle

# ── YouTube OAuth Redirect URI ────────────────────────
# Yerel geliştirme için: http://localhost:5000/callback/youtube
# VPS için: http://your-domain.com/callback/youtube
REDIRECT_URI=http://localhost:5000/callback/youtube
